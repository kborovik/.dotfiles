{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "WebSearch"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {},
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "ai@pydantic-skills": true,
    "logfire@pydantic-skills": true,
    "sdd@pilot-skills": true,
    "gh@pilot-skills": true
  },
  "extraKnownMarketplaces": {
    "pydantic-skills": {
      "source": {
        "source": "github",
        "repo": "pydantic/skills"
      },
      "autoUpdate": true
    },
    "pilot-skills": {
      "source": {
        "source": "github",
        "repo": "kborovik/pilot-skills"
      },
      "autoUpdate": true
    }
  },
  "effortLevel": "high",
  "autoUpdatesChannel": "stable",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-ansi",
  "editorMode": "vim"
}
