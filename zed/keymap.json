[
  {
    "bindings": {
      "cmd-shift-e": "project_panel::ToggleFocus",
      "cmd-shift-g": "git_panel::ToggleFocus",
      "f1": "command_palette::Toggle",
      "cmd-e": "file_finder::Toggle",
      "cmd-o": ["projects::OpenRecent", { "create_new_window": false }],
      "space g g": "git_graph::Open",
      "space g m": "git::OpenModifiedFiles",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-1": null,
      "ctrl-2": null,
      "ctrl-3": null,
      "ctrl-4": null,
      "ctrl-5": null,
      "ctrl-6": null,
      "ctrl-7": null,
      "ctrl-8": null,
      "ctrl-9": null,
      "cmd-1": ["workspace::ActivatePane", 0],
      "cmd-2": ["workspace::ActivatePane", 0],
      "cmd-3": ["workspace::ActivatePane", 0],
      "cmd-4": ["workspace::ActivatePane", 0],
      "cmd-5": ["workspace::ActivatePane", 0],
      "cmd-6": ["workspace::ActivatePane", 0],
      "cmd-7": ["workspace::ActivatePane", 0],
      "cmd-8": ["workspace::ActivatePane", 0],
      "cmd-9": ["workspace::ActivatePane", 0],
    },
  },
  {
    "context": "Pane",
    "bindings": {
      "cmd-1": ["pane::ActivateItem", 0],
      "cmd-2": ["pane::ActivateItem", 1],
      "cmd-3": ["pane::ActivateItem", 2],
      "cmd-4": ["pane::ActivateItem", 3],
      "cmd-5": ["pane::ActivateItem", 4],
      "cmd-6": ["pane::ActivateItem", 5],
      "cmd-7": ["pane::ActivateItem", 6],
      "cmd-8": ["pane::ActivateItem", 7],
      "cmd-9": ["pane::ActivateItem", 8],
      "cmd-0": "pane::ActivateLastItem",
    },
  },
  {
    "context": "Editor",
    "bindings": {},
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      "space": null,
    },
  },
  {
    "context": "vim_mode == normal && !menu",
    "bindings": {
      // Go Commands
      "g h": "vim::StartOfLine",
      "g l": "vim::EndOfLine",
      "g s": "vim::FirstNonWhitespace",
      // Register
      "space g r": "vim::ToggleRegistersView",
      // Git Commands
      "space g b": "git::Blame",
      "space g d": "git::Diff",
      // Window Commands
      "space w h": "workspace::ActivatePaneLeft",
      "space w l": "workspace::ActivatePaneRight",
      "space w k": "workspace::ActivatePaneUp",
      "space w j": "workspace::ActivatePaneDown",
      "space w s": "pane::SplitHorizontal",
      "space w v": "pane::SplitVertical",
      "space w w": "pane::CloseOtherItems",
    },
  },
]
